PROJECT_NAME           = "bcas"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
RECURSIVE              = YES
EXTRACT_ALL            = YES
INPUT                  = @DOXYGEN_INPUT_DIRS@
FILE_PATTERNS          = *.h *.hpp
FULL_PATH_NAMES        = NO
JAVADOC_AUTOBRIEF      = YES
WARN_IF_UNDOCUMENTED   = NO
